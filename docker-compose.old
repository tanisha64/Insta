
services:
  auth-service:
    build: ./Backend/auth-service
    # ports:
    #   - "3001:3001"
    env_file:
      - ./Backend/auth-service/.env
    restart: always

  media-service:
    build: ./Backend/media-service
    # ports:
    #   - "3002:3002"
    env_file:
      - ./Backend/media-service/.env
    restart: always

  post-service:
    build: ./Backend/post-service
    # ports:
    #   - "3003:3003"
    env_file:
      - ./Backend/post-service/.env
    restart: always

  user-service:
    build: ./Backend/user-service
    # ports:
    #   - "3004:3004"
    env_file:
      - ./Backend/user-service/.env
    restart: always

  nginx:
    image: nginx:latest
    ports:
      - "3000:3000"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - auth-service
      - user-service
      - post-service
      - media-service